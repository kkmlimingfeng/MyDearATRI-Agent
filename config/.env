# MyDearATRI-Agent 环境变量配置
# 将对应的 API Key 填入等号右侧即可
# 注意：本文件包含敏感信息，请勿提交到 Git

# ===== LLM 服务 API Keys =====
# 使用 ModelScope 推理 API 时，将 ModelScope Token 填入 OPENAI_API_KEY
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api-inference.modelscope.cn/v1
OPENAI_MODEL_NAME=Qwen/Qwen3.5-397B-A17B

# ===== 搜索/工具 API Keys =====
TAVILY_API_KEY=

# ===== 沙箱配置 =====
# firejail 沙箱中允许写入的路径，留空则默认使用当前用户主目录，确保sudo apt install firejail
SANDBOX_WRITE_PATH=
